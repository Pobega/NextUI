-            printf("Number of Balls: %d\n", SDL_JoystickNumBalls(Globals::g_joy));
+    // Open every joystick, not just index 0: on some devices (e.g. the
+    // Powkiddy V90S) other input nodes enumerate as joysticks ahead of the
+    // built-in gamepad, and events carry per-device button numbers anyway.
+    for (int i = 0; i < SDL_NumJoysticks(); ++i) {
+        SDL_Joystick *joy = SDL_JoystickOpen(i);
+        if (joy) {
+            printf("Opened Joystick %d\n", i);
+            printf("Name: %s\n", SDL_JoystickNameForIndex(i));
+            printf("Number of Axes: %d\n", SDL_JoystickNumAxes(joy));
+            printf("Number of Buttons: %d\n", SDL_JoystickNumButtons(joy));
+            printf("Number of Balls: %d\n", SDL_JoystickNumBalls(joy));
+            if (Globals::g_joy == NULL) Globals::g_joy = joy;
         } else {
-            printf("Couldn't open Joystick 0\n");
+            printf("Couldn't open Joystick %d\n", i);
         }
-        
     }
 
     // Hide cursor before creating the output surface.
