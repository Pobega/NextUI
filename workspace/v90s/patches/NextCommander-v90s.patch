diff --git a/Makefile b/Makefile
index dbf0750..6fd9568 100644
--- a/Makefile
+++ b/Makefile
@@ -8,8 +8,43 @@ endif
 CXXFLAGS := -Os
 #endif
 
+# platform dependant stuff - v90s (Powkiddy V90S)
+ifeq ($(PLATFORM),v90s)
+SDCARD_ROOT := /mnt/SDCARD
+NEXTUI_SYSTEM_PATH := $(SDCARD_ROOT)/.system
+
+CXXFLAGS += -DPATH_DEFAULT=\"$(SDCARD_ROOT)\"
+CXXFLAGS += -DPATH_DEFAULT_RIGHT=\"$(SDCARD_ROOT)\"
+CXXFLAGS += -DFILE_SYSTEM=\"/dev/mmcblk1p1\"
+
+# Keys
+# Joys for the built-in adc_gamepad. SDL assigns joystick button indices in
+# ascending evdev keycode order and the pad's buttons start at BTN_SOUTH
+# (304): 304 305 307 308 310 311 312 313 314 315 316 -> 0..10. The dpad is
+# keyboard-style (KEY_UP/DOWN/LEFT/RIGHT) and arrives as SDLK_* events.
+CXXFLAGS += -DCMDR_KEY_UP=SDLK_UP
+CXXFLAGS += -DCMDR_KEY_RIGHT=SDLK_RIGHT
+CXXFLAGS += -DCMDR_KEY_DOWN=SDLK_DOWN
+CXXFLAGS += -DCMDR_KEY_LEFT=SDLK_LEFT
+CXXFLAGS += -DCMDR_KEY_OPEN=0		# A (304)
+CXXFLAGS += -DCMDR_KEY_PARENT=1		# B (305)
+CXXFLAGS += -DCMDR_KEY_OPERATION=2	# X (307)
+CXXFLAGS += -DCMDR_KEY_SYSTEM=3		# Y (308)
+CXXFLAGS += -DCMDR_KEY_PAGEUP=4		# L1 (310)
+CXXFLAGS += -DCMDR_KEY_PAGEDOWN=5	# R1 (311)
+CXXFLAGS += -DCMDR_KEY_SELECT=8		# SELECT (314)
+CXXFLAGS += -DCMDR_KEY_TRANSFER=9	# START (315)
+CXXFLAGS += -DCMDR_KEY_MENU=10		# MENU (316)
+
+# Screen: 3.5" 640x480
+CXXFLAGS += -DAUTOSCALE=1
+CXXFLAGS += -DAUTOSCALE_DPI=0
+CXXFLAGS += -DPPU_X=2
+CXXFLAGS += -DPPU_Y=2
+CXXFLAGS += -DSCREEN_BPP=32
+
 # platform dependant stuff - tg5040 and tg5050
-ifneq (,$(findstring tg50,$(PLATFORM)))
+else ifneq (,$(findstring tg50,$(PLATFORM)))
 SDCARD_ROOT := /mnt/SDCARD
 NEXTUI_SYSTEM_PATH := $(SDCARD_ROOT)/.system
 
